# Treqe Backend - Environment Variables
# Copy this file to .env and adjust values

# General
ENVIRONMENT=development
APP_NAME=Treqe Backend
APP_VERSION=1.0.0

# Database
DATABASE_URL=sqlite+aiosqlite:///treqe_demo.db  # Temporal para pruebas demo
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10

# Authentication
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (JSON array)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Treqe Algorithm
TREQE_K_MAX=6
TREQE_TIMEOUT_SECONDS=5
TREQE_MIN_REPUTATION=30

# Commission Rates
COMMISSION_RATE_LOW=0.08    # 8% for reputation < 60
COMMISSION_RATE_MEDIUM=0.06 # 6% for reputation 60-79
COMMISSION_RATE_HIGH=0.04   # 4% for reputation >= 80

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/treqe.log

# Email (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@treqe.com